# ===================================
# Java & Maven
# ===================================
# Maven构建目录
**/target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# 编译输出
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Maven本地仓库（如果误放在项目中）
.m2/

# ===================================
# IDE - IntelliJ IDEA
# ===================================
.idea/
*.iws
*.iml
*.ipr
out/

# IDEA自动生成的文件（保留部分配置）
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/vcs.xml
!.idea/.gitignore

# ===================================
# IDE - Eclipse
# ===================================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.loadpath
.recommenders

# ===================================
